extends layout

block content
    section.page-header
        .container
            h1 Contact Us
            p.lead We are here to help you with all your automotive needs.

    section.contact-section
        .container
            .contact-header
                h2 Get In Touch
                p Have questions about our models or services? Our team is ready to assist you.
                .info-items-horizontal
                    .info-item
                        i.fas.fa-map-marker-alt
                        div
                            h4 Location
                            p Beverly Hills, CA
                    .info-item
                        i.fas.fa-phone-alt
                        div
                            h4 Phone
                            p +237 695 73 98 44
                    .info-item
                        i.fas.fa-envelope
                        div
                            h4 Email
                            p info@exodusmotors.com

            .contact-grid-main
                .contact-image
                    .map-placeholder
                        img(src="/images/hero.png", alt="Our Showroom")
                
                .contact-form-container
                    h2 Send us a Message
                    form#contactForm.contact-form
                        .form-row
                            .form-group
                                label(for="name") Full Name
                                input(type="text", id="name", name="name", placeholder="Your Name", required)
                            .form-group
                                label(for="email") Email Address
                                input(type="email", id="email", name="email", placeholder="Your Email", required)
                        .form-group
                            label(for="message") Your Message
                            textarea(id="message", name="message", rows="5", placeholder="How can we help you?", required)
                        button.btn.btn-primary(type="submit") Send Message
